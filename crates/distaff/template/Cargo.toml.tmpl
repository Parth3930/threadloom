[package]
license = "MIT"
description = "A meticulously crafted Rust full-stack framework."
name = "demo"
version = "0.1.0"
edition = "2021"
default-run = "demo"

[[bin]]
name = "desktop"
path = "src/bin/desktop.rs"
required-features = ["desktop"]

[package.metadata.packager]
product-name = "Threadloom App"
identifier = "com.threadloom.app"
resources = ["dist"]
icons = ["assets/icon.png", "assets/icon.ico"]

[dependencies]
threadloom = "*"
serde = { version = "1.0", features = ["derive"] }
threadloom-core = "*"
threadloom-macro = "*"
threadloom-dom = "*"
threadloom-ui = "*"
threadloom-server = "*"
web-sys = { version = "0.3", features = ["Window", "Document", "Element", "HtmlElement", "HtmlInputElement", "HtmlTextAreaElement", "HtmlSelectElement", "Location", "Response", "console", "History"] }
wasm-bindgen-futures = "0.4"
reqwasm = "0.5"
[features]
desktop = ["dep:threadloom-desktop"]

[target.'cfg(not(target_arch = "wasm32"))'.dependencies]
actix-web = "4"
actix-files = "0.6"
env_logger = "0.11"
dotenvy = "0.15"
log = "0.4"
threadloom-desktop = { optional = true, version = "*" }
threadloom = { features = ["actix"], version = "*" }

[workspace]
